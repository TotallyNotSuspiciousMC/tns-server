{
  "config_version": 2,
  "__comment": "Before changing anything, see https://github.com/Patbox/StyledPlayerList#configuration",
  "default_style": "default",
  "messages": {
    "switch": "Your player list style has been changed to: <gold>${style}</gold>",
    "unknown": "<red>This style doesn't exist!</red>",
    "no_permission": "<red>You don't have required permissions!</red>"
  },
  "player": {
    "modify_name": true,
    "modify_right_text": false,
    "modify_list_order": false,
    "modify_visibility": false,
    "passthrough": false,
    "hidden": false,
    "format": "%player:displayname%",
    "right_text": "",
    "update_on_chat_message": false,
    "update_tick_time": 1200,
    "styles": [
      {
        "require": {
          "type": "permission",
          "permission": "group.owner"
        },
        "format": "<color:#020000>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.administrator"
        },
        "format": "<color:#b60000>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.builder"
        },
        "format": "<color:#34fff6>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.moderator"
        },
        "format": "<color:#fc5f00>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.trial-moderator"
        },
        "format": "<color:#fc5f00>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.discord-moderator"
        },
        "format": "<color:#be4bca>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.trial-discord-moderator"
        },
        "format": "<color:#be4bca>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.helper"
        },
        "format": "<color:#f1c40f>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.trial-helper"
        },
        "format": "<color:#f1c40f>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.discord-helper"
        },
        "format": "<color:#ff6700>%player:displayname%</color>",
        "passthrough": false
      },
      {
        "require": {
          "type": "permission",
          "permission": "group.trial-discord-helper"
        },
        "format": "<color:#ff6700>%player:displayname%</color>",
        "passthrough": false
      }
    ]
  },
  "client_show_in_singleplayer": true
}